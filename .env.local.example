# Environment Variables Template
# Copy this to .env.local and fill in your values

# Apify API Key (from apify.com → Account → Integrations)
APIFY_API_KEY=your_apify_token_here

# Note: For Vercel deployment, set these in the Vercel dashboard under Settings → Environment Variables
# Brevo API key should be set as BREVO_API_KEY in Vercel